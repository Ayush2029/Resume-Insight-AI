# ─────────────────────────────────────────────────────────────
# ResumeInsight AI — Environment Variables
# Copy this file to .env.local and fill in your keys.
# .env.local is git-ignored and will NEVER be committed.
# ─────────────────────────────────────────────────────────────

# GROQ API KEY  (required — for AI Project Summary feature)
# Free key:  https://console.groq.com
# Steps:     Sign up → API Keys → Create API Key
# Starts with: gsk_
GROQ_API_KEY=gsk_your_groq_api_key_here

# GITHUB PERSONAL ACCESS TOKEN  (optional but strongly recommended)
# Without token: 60 unauthenticated requests/hour
# With token:    5000 requests/hour
# Free token:    https://github.com/settings/tokens
# Steps:         Generate new token (classic) → no scopes needed → copy
# Starts with:   ghp_
GITHUB_TOKEN=ghp_your_github_token_here
